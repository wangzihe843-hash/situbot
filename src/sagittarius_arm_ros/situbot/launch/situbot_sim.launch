<launch>
  <!-- SituBot Simulation: Gazebo + MoveIt + SituBot pipeline -->
  <!-- Launches the existing sagittarius Gazebo and MoveIt, then starts SituBot nodes -->

  <arg name="api_key" default="" />
  <arg name="model" default="qwen-plus" />

  <!-- 1. Launch Gazebo with sagittarius arm -->
  <include file="$(find sagittarius_gazebo)/launch/demo_gazebo.launch">
    <!-- TODO: verify launch args match your Gazebo setup -->
  </include>

  <!-- 2. Launch MoveIt -->
  <include file="$(find sagittarius_moveit)/launch/move_group.launch">
    <!-- TODO: verify launch args -->
  </include>

  <!-- 3. Launch SituBot full pipeline -->
  <include file="$(find situbot)/launch/situbot_full.launch">
    <arg name="api_key" value="$(arg api_key)" />
    <arg name="model" value="$(arg model)" />
    <arg name="start_usb_cam" value="false" />
    <arg name="camera_topic" value="/camera/color/image_raw" />
  </include>

</launch>
